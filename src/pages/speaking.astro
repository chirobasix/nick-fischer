---
import PageLayout from '../layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';
import {
  abs, withBrand,
  buildPerson, buildOrganization, buildWebSite, buildWebPage,
  buildSpeakerEvents, buildFaqPage, type SpeakingEvent,
} from '../lib/seo';

const title = withBrand('Speaking — Keynotes for Chiropractic Events');
const description =
  'Book Nick Fischer to speak. Keynotes and workshops on chiropractic practice growth, marketing systems, patient generation, and AI for chiropractors — for events nationwide.';

// Real engagements only — never fabricate. Newest first.
const events: SpeakingEvent[] = [
  {
    name: 'AI for Chiropractors in 2026: The Complete Guide + Live Demos',
    startDate: '2026-01-17',
    videoUrl: 'https://www.youtube.com/watch?v=6ahP2srFosU',
  },
];

// Format an ISO date (YYYY-MM-DD) as "January 17, 2026" at build time.
const fmtDate = (iso: string) =>
  new Date(`${iso}T00:00:00`).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });

const topics = [
  { icon: 'lucide:layout-grid', title: 'Marketing as a System', body: 'Why campaigns fail and systems compound — the framework that turns a practice into a patient magnet.' },
  { icon: 'lucide:sparkles', title: 'AI for Chiropractors', body: 'Practical ways to use AI and answer-engine optimization to get found and book more new patients.' },
  { icon: 'lucide:target', title: 'Patient Generation That Lasts', body: 'Paid, local SEO, reputation, and automation working together instead of competing for budget.' },
  { icon: 'lucide:line-chart', title: 'The 5-Year Practice', body: 'Building marketing that grows enterprise value, not just this month\'s lead count.' },
];

const faqs = [
  { question: 'What does Nick Fischer speak about?', answer: 'Chiropractic practice growth, marketing systems, patient generation, local SEO, reputation, CRM automation, and using AI / answer-engine optimization to get found by more patients.' },
  { question: 'What kinds of events does Nick speak at?', answer: 'Chiropractic industry conferences, association meetings, mastermind groups, and corporate or franchise events — keynotes, breakout sessions, and hands-on workshops.' },
  { question: 'How do I book Nick to speak?', answer: 'Use the contact page to share your event date, audience, and format. You\'ll get a fast reply with availability and fit.' },
];

const jsonLd = [
  buildPerson(),
  buildOrganization(),
  buildWebSite(),
  buildWebPage({ url: abs('/speaking/'), name: title, description }),
  buildFaqPage(faqs),
  buildSpeakerEvents(events),
].filter(Boolean) as object[];
---
<PageLayout title={title} description={description} jsonLd={jsonLd}>
  <section class="page-hero">
    <div class="container-page">
      <p class="eyebrow">Speaking</p>
      <h1 class="h-display page-title">Talks that send chiropractors home with a plan.</h1>
      <p class="lead page-dek">
        I speak at chiropractic events across the country on practice growth, marketing
        systems, and AI — energetic, specific, and built so the audience leaves with
        steps they can run on Monday morning.
      </p>
      <a href="/contact/" class="btn btn-primary">Book Nick to speak <Icon name="lucide:arrow-right" width="18" height="18" /></a>
    </div>
  </section>

  <section class="section">
    <div class="container-page">
      <div class="section-head" data-reveal>
        <p class="eyebrow">Signature topics</p>
        <h2 class="h-display">What I bring to the stage</h2>
      </div>
      <div class="topics">
        {topics.map((t) => (
          <article class="card topic" data-reveal>
            <span class="topic-icon"><Icon name={t.icon} width="22" height="22" /></span>
            <h3>{t.title}</h3>
            <p>{t.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  {events.length > 0 && (
    <section class="section section-alt">
      <div class="container-page">
        <div class="section-head" data-reveal>
          <p class="eyebrow">Talks</p>
          <h2 class="h-display">Recent talks &amp; appearances</h2>
        </div>
        <ul class="events">
          {events.map((e) => (
            <li class="event" data-reveal>
              <div class="event-main">
                {e.startDate && <time class="event-date" datetime={e.startDate}>{fmtDate(e.startDate)}</time>}
                <span class="event-name">{e.name}</span>
                {e.location && <span class="event-loc"><Icon name="lucide:map-pin" width="14" height="14" /> {e.location}</span>}
              </div>
              {(e.videoUrl || e.url) && (
                <a class="event-link" href={e.videoUrl ?? e.url} target="_blank" rel="noopener">
                  {e.videoUrl ? 'Watch the talk' : 'Event details'} <Icon name="lucide:arrow-up-right" width="16" height="16" />
                </a>
              )}
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <section class="section">
    <div class="container-page faq">
      <h2 class="h-display">Speaking FAQ</h2>
      <dl>
        {faqs.map((f) => (
          <div class="faq-item" data-reveal>
            <dt>{f.question}</dt>
            <dd>{f.answer}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>
</PageLayout>

<style>
  .page-hero { background: linear-gradient(180deg, var(--color-n-50), var(--color-n-0)); padding-block: 3.5rem 2.5rem; }
  .page-title { font-size: clamp(2rem, 4.5vw, 3.1rem); margin: 0.5rem 0 0; max-width: 20ch; }
  .page-dek { margin-top: 1.25rem; max-width: 60ch; margin-bottom: 1.75rem; }

  .section-alt { background: var(--color-n-50); border-block: 1px solid var(--color-n-100); }
  .section-head { max-width: 40ch; margin-bottom: 2.5rem; }
  .section-head h2 { font-size: clamp(1.75rem, 3.5vw, 2.4rem); margin: 0.5rem 0 0; }

  .topics { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.25rem; }
  .topic { padding: 1.75rem; }
  .topic-icon { display: inline-grid; place-items: center; width: 46px; height: 46px; border-radius: var(--radius-md); background: var(--color-gold-100); color: var(--color-gold-600); margin-bottom: 1rem; }
  .topic h3 { font-family: var(--font-display); font-size: 1.2rem; margin: 0 0 0.5rem; }
  .topic p { color: var(--color-n-600); margin: 0; }

  .events { list-style: none; padding: 0; margin: 0; display: grid; gap: 0.85rem; }
  .event {
    display: flex; align-items: center; justify-content: space-between; gap: 1.25rem;
    flex-wrap: wrap; padding: 1.1rem 1.25rem; background: #fff;
    border: 1px solid var(--color-n-200); border-radius: var(--radius-md);
  }
  .event-main { display: flex; flex-direction: column; gap: 0.25rem; }
  .event-date { font-size: 0.8rem; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; color: var(--color-accent); }
  .event-name { font-family: var(--font-display); font-weight: 700; font-size: 1.1rem; color: var(--color-ink); }
  .event-loc { display: inline-flex; align-items: center; gap: 0.35rem; color: var(--color-n-500); font-size: 0.9rem; }
  .event-loc [data-icon] { color: var(--color-n-400); }
  .event-link {
    display: inline-flex; align-items: center; gap: 0.4rem; flex: none;
    font-weight: 600; color: var(--color-accent);
  }
  .event-link:hover { gap: 0.6rem; }

  .faq { max-width: 60rem; }
  .faq h2 { font-size: clamp(1.6rem, 3vw, 2.2rem); margin: 0 0 1.5rem; }
  .faq-item { border-top: 1px solid var(--color-n-200); padding: 1.25rem 0; }
  .faq-item dt { font-family: var(--font-display); font-weight: 700; font-size: 1.1rem; color: var(--color-ink); }
  .faq-item dd { margin: 0.5rem 0 0; color: var(--color-n-600); }

  @media (max-width: 760px) { .topics { grid-template-columns: 1fr; } }
</style>
