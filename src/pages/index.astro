---
import PageLayout from '../layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';
import {
  abs, withBrand,
  buildPerson, buildOrganization, buildWebSite, buildProfilePage,
  buildBook, buildPodcastSeries,
} from '../lib/seo';

const title = withBrand('Nick Fischer — Chiropractic Marketing Consultant, Author & Speaker');
const description =
  'Nick Fischer is the founder of CHIROBASIX, author of The Chiropractor\'s Marketing Playbook, and host of The Chiropractic Practice Success Podcast — helping chiropractors grow with marketing that works as a system.';

// Home is a ProfilePage about the Person. The whole entity graph ships here so
// Google + AI engines can resolve "Nick Fischer" to a single, well-described node.
const jsonLd = [
  buildPerson(),
  buildOrganization(),
  buildWebSite(),
  buildBook(),
  buildPodcastSeries(),
  buildProfilePage({ url: abs('/'), name: 'Nick Fischer', description }),
];

const pillars = [
  {
    icon: 'lucide:trending-up',
    title: 'Founder, CHIROBASIX',
    body: 'A marketing agency built exclusively for chiropractors — proven patient-generation systems, not one-off campaigns.',
    href: 'https://chirobasix.com',
    cta: 'Visit CHIROBASIX',
    external: true,
  },
  {
    icon: 'lucide:mic',
    title: 'Podcast Host',
    body: 'The Chiropractic Practice Success Podcast — candid conversations and tactics for building a thriving practice.',
    href: '/podcast/',
    cta: 'Listen to the show',
  },
  {
    icon: 'lucide:book-open',
    title: 'Author',
    body: 'The Chiropractor\'s Marketing Playbook — the system for turning a chiropractic practice into a patient magnet.',
    href: '/book/',
    cta: 'Explore the book',
  },
  {
    icon: 'lucide:presentation',
    title: 'Speaker',
    body: 'Keynotes and workshops at chiropractic events nationwide on practice growth, marketing systems, and AI.',
    href: '/speaking/',
    cta: 'Book Nick to speak',
  },
];

const stats = [
  { value: '200+', label: 'Practices served' },
  { value: '$3M+', label: 'Yearly ad spend managed' },
  { value: '10+', label: 'Years in marketing' },
];

// Nick's signature framework — the talk he gives ("The 4 Pillars of Chiropractic Marketing").
const methodPillars = [
  { n: '01', title: 'Website', body: 'A site built to turn visitors into booked new patients — your conversion foundation.' },
  { n: '02', title: 'Google', body: 'Local SEO, your Google Business Profile, and reviews so patients find you on the map.' },
  { n: '03', title: 'Social', body: 'Paid and organic social that keeps the new-patient pipeline full month after month.' },
  { n: '04', title: 'CRM', body: 'Automation and follow-up so no lead slips through — and patients keep coming back.' },
];

// Real client video testimonials (CHIROBASIX YouTube). The `stat`/`note` come
// straight from each client's own on-camera words — quantified, sourced proof.
const testimonials = [
  {
    id: 'orJuHbq9v3A', name: 'Dr. Levi McQueary', practice: 'The Ridge Chiropractic',
    stat: '108 new patients in month one', note: 'He hoped for 60 — and landed 108. Over 400 new patients in his first four months.',
  },
  {
    id: '9gOE8Vt25MM', name: 'Dr. Ernest Luong', practice: 'Resilience Chiropractic',
    stat: '40–80 new patients a month', note: 'A consistent stream of new patients coming through the door, month after month.',
  },
  {
    id: 'VnZ5wISiIgQ', name: 'Dr. John Carleton', practice: 'Wave Chiropractic',
    stat: '300+ new patients in 10 months', note: 'Averaging 20+ new patients actually walking in every month — booked, not just leads.',
  },
  {
    id: 'WUfdnBG0eIQ', name: 'Dr. Sean Flaherty', practice: 'Narrows Chiropractic',
    stat: '3× more new patients a month', note: 'From roughly 10 new patients a month to about 30 — straight from showing up online.',
  },
];
---
<PageLayout title={title} description={description} ogType="profile" jsonLd={jsonLd} preloadImage="/img/hero-nick.png">
  <!-- Hero -->
  <section class="hero">
    <div class="container-page hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Digital marketer · Founder of CHIROBASIX</p>
        <h1 class="h-display hero-title">
          Marketing is a system — <span class="accent">not a campaign.</span>
        </h1>
        <p class="lead hero-lead">
          I'm Nick Fischer. I help chiropractors across the country dominate online
          so they can help more patients — through data-driven strategy, creative
          that converts, and systems that compound month after month.
        </p>
        <ul class="hero-creds">
          <li><Icon name="lucide:check" width="16" height="16" /> Author, <em>The Chiropractor's Marketing Playbook</em></li>
          <li><Icon name="lucide:check" width="16" height="16" /> Host, <em>Chiropractic Practice Success Podcast</em></li>
          <li><Icon name="lucide:check" width="16" height="16" /> National speaker &amp; presenter</li>
          <li><Icon name="lucide:check" width="16" height="16" /> Marketing degree, Grand Valley State</li>
        </ul>
        <div class="hero-actions">
          <a href="/about/" class="btn btn-primary">Meet Nick <Icon name="lucide:arrow-right" width="18" height="18" /></a>
          <a href="/speaking/" class="btn btn-ghost">Book a talk</a>
        </div>
        <ul class="hero-stats">
          {stats.map((s) => (
            <li><strong>{s.value}</strong><span>{s.label}</span></li>
          ))}
        </ul>
      </div>

      <div class="hero-photo">
        <img src="/img/hero-nick.png" width="526" height="800" alt="Nick Fischer speaking on stage" fetchpriority="high" decoding="async" />
      </div>
    </div>
  </section>

  <!-- Mission -->
  <section class="mission-band">
    <div class="container-page" data-reveal>
      <p class="mission-eyebrow">The mission</p>
      <p class="mission-text">Help <strong>1 million people</strong> get out of pain — naturally.</p>
      <p class="mission-sub">By connecting patients with great chiropractors — and helping those practices reach more of the people who need them.</p>
    </div>
  </section>

  <!-- Pillars -->
  <section class="section">
    <div class="container-page">
      <div class="section-head" data-reveal>
        <p class="eyebrow">What I do</p>
        <h2 class="h-display">Four ways I help practices grow</h2>
      </div>
      <div class="pillars">
        {pillars.map((p) => (
          <article class="card pillar" data-reveal>
            <span class="pillar-icon"><Icon name={p.icon} width="22" height="22" /></span>
            <h3>{p.title}</h3>
            <p>{p.body}</p>
            <a href={p.href} class="pillar-link" {...(p.external ? { target: '_blank', rel: 'noopener' } : {})}>
              {p.cta} <Icon name="lucide:arrow-right" width="16" height="16" />
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Signature framework -->
  <section class="section section-alt">
    <div class="container-page">
      <div class="section-head" data-reveal>
        <p class="eyebrow">My framework</p>
        <h2 class="h-display">The Digital Dominance System</h2>
        <p class="lead">Patients don't choose the best chiropractor — they choose the one they see everywhere. My Digital Dominance System makes you that practice: omnipresent across every place a future patient looks, so you become the obvious, top-of-mind choice.</p>
      </div>
      <div class="method-grid">
        {methodPillars.map((m) => (
          <article class="method" data-reveal>
            <span class="method-num">{m.n}</span>
            <h3>{m.title}</h3>
            <p>{m.body}</p>
          </article>
        ))}
      </div>
      <p class="method-note">Those four are the digital core — and the system extends across email, AI-search optimization, workshops, and referrals. A hub-and-spoke setup where every channel feeds new patients to your door, so you're not betting the practice on any single one.</p>
      <a href="https://www.youtube.com/watch?v=VmSEsOBoHSo" class="method-watch" target="_blank" rel="noopener">Watch the talk <Icon name="lucide:arrow-up-right" width="16" height="16" /></a>
    </div>
  </section>

  <!-- Philosophy / quote -->
  <section class="quote-band">
    <div class="container-page quote-grid" data-reveal>
      <div class="quote-media">
        <img src="/img/speaking-b.jpg" width="1400" height="935" alt="Nick Fischer speaking on stage at a chiropractic event" loading="lazy" decoding="async" />
      </div>
      <div>
        <blockquote class="quote">
          “True marketing is a system, not a campaign. It's not about how many leads
          you get this month — it's where your practice is going to be 6 months,
          12 months, and 5 years from now.”
        </blockquote>
        <p class="quote-by">— Nick Fischer</p>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="section">
    <div class="container-page">
      <div class="section-head" data-reveal>
        <p class="eyebrow">Proof</p>
        <h2 class="h-display">Real results from real practices</h2>
        <p class="lead">Don't take my word for it. Here's what changed for chiropractors after we built their growth system — in their own words.</p>
      </div>
      <ul class="testimonials">
        {testimonials.map((t) => (
          <li class="testimonial" data-reveal>
            <div class="video" data-yt={t.id}>
              <button class="video-btn" type="button" aria-label={`Play testimonial from ${t.name}`}>
                <img src={`https://i.ytimg.com/vi/${t.id}/hqdefault.jpg`} width="480" height="360" alt={`${t.name} — ${t.practice}`} loading="lazy" decoding="async" />
                <span class="video-play" aria-hidden="true"><Icon name="lucide:play" width="24" height="24" /></span>
              </button>
            </div>
            <p class="testimonial-stat">{t.stat}</p>
            <p class="testimonial-note">{t.note}</p>
            <p class="testimonial-by"><strong>{t.name}</strong><span>{t.practice}</span></p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section-alt">
    <div class="container-page cta" data-reveal>
      <div>
        <h2 class="h-display">Let's build your growth system.</h2>
        <p class="lead">Speaking, podcast guesting, media, or working with my agency — start here.</p>
      </div>
      <a href="/contact/" class="btn btn-primary">Get in touch <Icon name="lucide:arrow-right" width="18" height="18" /></a>
    </div>
  </section>

  {/* Click-to-load facade for testimonial videos — no iframe until clicked. */}
  <script is:inline>
    document.querySelectorAll('.video[data-yt]').forEach(function (el) {
      var btn = el.querySelector('.video-btn');
      if (!btn) return;
      btn.addEventListener('click', function () {
        var ifr = document.createElement('iframe');
        ifr.src = 'https://www.youtube-nocookie.com/embed/' + el.getAttribute('data-yt') + '?autoplay=1';
        ifr.title = 'Video testimonial';
        ifr.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share';
        ifr.allowFullscreen = true;
        ifr.loading = 'lazy';
        el.innerHTML = '';
        el.appendChild(ifr);
      });
    });
  </script>
</PageLayout>

<style>
  .hero {
    position: relative;
    background:
      radial-gradient(1100px 480px at 85% -10%, var(--color-accent-100), transparent 60%),
      linear-gradient(180deg, var(--color-n-50), var(--color-n-0));
    padding-block: 2.25rem 0;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 3rem;
    align-items: end;
  }
  .hero-copy { padding-bottom: 3rem; }
  .hero-title { font-size: clamp(2.25rem, 5vw, 3.6rem); margin: 0.75rem 0 0; }
  .accent { color: var(--color-accent); }
  .hero-lead { margin-top: 1.25rem; max-width: 52ch; }
  .hero-creds {
    list-style: none; padding: 0; margin: 1.75rem 0 0;
    display: grid; grid-template-columns: 1fr 1fr; gap: 0.6rem 1.5rem;
  }
  .hero-creds li { display: flex; gap: 0.5rem; align-items: start; font-size: 0.92rem; color: var(--color-n-600); }
  .hero-creds em { color: var(--color-ink); font-style: italic; }
  .hero-creds [data-icon] { color: var(--color-accent); flex: none; margin-top: 2px; }
  .hero-actions { display: flex; gap: 0.75rem; margin-top: 1.75rem; flex-wrap: wrap; }
  .hero-stats {
    display: flex; gap: 2.5rem; margin: 2.25rem 0 0; padding: 0; list-style: none;
    border-top: 1px solid var(--color-n-200); padding-top: 1.5rem;
  }
  .hero-stats li { display: flex; flex-direction: column; }
  .hero-stats strong { font-family: var(--font-display); font-size: 1.75rem; color: var(--color-navy); }
  .hero-stats span { font-size: 0.85rem; color: var(--color-n-400); max-width: 18ch; }

  /* Large transparent cutout, anchored to the bottom so it rises up from
     behind the navy mission band below. */
  .hero-photo { align-self: end; display: flex; justify-content: center; }
  .hero-photo img {
    width: 100%; max-width: 440px; height: auto; display: block;
    margin-bottom: -2.5rem;            /* dip behind the mission bar */
    filter: drop-shadow(0 26px 34px rgba(20, 37, 59, 0.26));
  }

  .section-head { max-width: 40ch; margin-bottom: 2.5rem; }
  .section-head h2 { font-size: clamp(1.75rem, 3.5vw, 2.5rem); margin: 0.5rem 0 0; }

  .pillars { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.25rem; }
  .pillar { padding: 1.75rem; display: flex; flex-direction: column; }
  .pillar-icon {
    display: inline-grid; place-items: center; width: 46px; height: 46px;
    border-radius: var(--radius-md); background: var(--color-accent-100); color: var(--color-accent-700);
    margin-bottom: 1rem;
  }
  .pillar h3 { font-family: var(--font-display); font-size: 1.2rem; margin: 0 0 0.5rem; }
  .pillar p { color: var(--color-n-600); margin: 0 0 1.25rem; }
  .pillar-link {
    margin-top: auto; display: inline-flex; align-items: center; gap: 0.4rem;
    font-weight: 600; color: var(--color-accent);
  }
  .pillar-link:hover { gap: 0.65rem; }

  .quote-band { background: var(--color-n-50); border-block: 1px solid var(--color-n-100); padding-block: 4rem; }
  .quote-grid { display: grid; grid-template-columns: 0.85fr 1.15fr; gap: 3rem; align-items: center; }
  .quote-media img { width: 100%; height: auto; aspect-ratio: 3 / 2; object-fit: cover; border-radius: var(--radius-xl); box-shadow: var(--shadow-lg); display: block; }
  .quote {
    font-family: var(--font-display); font-weight: 700;
    font-size: clamp(1.4rem, 3vw, 2.1rem); line-height: 1.3; letter-spacing: -0.01em;
    color: var(--color-ink); margin: 0; text-wrap: balance;
  }
  .quote-by { margin-top: 1.25rem; color: var(--color-n-500); font-weight: 600; }
  @media (max-width: 860px) { .quote-grid { grid-template-columns: 1fr; } }

  .section-alt { background: var(--color-n-50); border-block: 1px solid var(--color-n-100); }
  .section-head .lead { margin-top: 0.75rem; }

  .method-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.25rem; }
  .method { background: #fff; border: 1px solid var(--color-n-200); border-radius: var(--radius-lg); padding: 1.5rem; }
  .method-num { font-family: var(--font-display); font-weight: 800; font-size: 1.1rem; color: var(--color-gold); }
  .method h3 { font-family: var(--font-display); font-size: 1.2rem; margin: 0.5rem 0 0.4rem; }
  .method p { color: var(--color-n-600); margin: 0; font-size: 0.95rem; }
  .method-note { color: var(--color-n-600); font-size: 0.95rem; max-width: 62ch; margin: 1.5rem 0 0; }
  .method-watch { display: inline-flex; align-items: center; gap: 0.4rem; margin-top: 1.25rem; font-weight: 600; color: var(--color-accent); }
  .method-watch:hover { gap: 0.65rem; }

  .mission-band { position: relative; z-index: 1; background: var(--color-navy); color: #fff; padding-block: 3rem; }
  .mission-eyebrow { color: var(--color-gold); font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; font-size: 0.8rem; margin: 0; }
  .mission-text { font-family: var(--font-display); font-weight: 800; font-size: clamp(1.6rem, 4vw, 2.6rem); line-height: 1.2; margin: 0.75rem 0 0; max-width: 22ch; text-wrap: balance; }
  .mission-text strong { color: var(--color-gold); }
  .mission-sub { color: var(--color-n-200); margin: 1rem 0 0; max-width: 54ch; font-size: 1.0625rem; }

  .testimonials { list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.25rem; }
  .testimonial { display: flex; flex-direction: column; }
  .testimonial-stat { font-family: var(--font-display); font-weight: 800; font-size: 1.15rem; line-height: 1.25; color: var(--color-navy); margin: 0.9rem 0 0; text-wrap: balance; }
  .testimonial-note { color: var(--color-n-600); font-size: 0.9rem; margin: 0.4rem 0 0; }
  .testimonial-by { margin: 0.9rem 0 0; padding-top: 0.85rem; border-top: 1px solid var(--color-n-200); display: flex; flex-direction: column; }
  .testimonial-by strong { font-family: var(--font-display); font-size: 1rem; color: var(--color-ink); }
  .testimonial-by span { color: var(--color-n-500); font-size: 0.85rem; }

  .video { position: relative; aspect-ratio: 16 / 9; border-radius: var(--radius-md); overflow: hidden; box-shadow: var(--shadow-md); background: #000; }
  .video-btn { position: absolute; inset: 0; width: 100%; height: 100%; padding: 0; border: 0; cursor: pointer; background: none; display: block; }
  .video-btn img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .video-play { position: absolute; inset: 0; margin: auto; width: 56px; height: 56px; display: grid; place-items: center; border-radius: 999px; background: rgba(20,37,59,.85); color: #fff; transition: transform var(--duration-base) var(--ease-out), background var(--duration-base); }
  .video-btn:hover .video-play { transform: scale(1.08); background: var(--color-accent); }
  .video :global(iframe) { width: 100%; height: 100%; border: 0; display: block; }

  @media (max-width: 860px) { .method-grid, .testimonials { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 520px) { .method-grid, .testimonials { grid-template-columns: 1fr; } }

  .cta {
    display: flex; align-items: center; justify-content: space-between; gap: 2rem; flex-wrap: wrap;
    background: linear-gradient(120deg, var(--color-accent-100), var(--color-n-50));
    border: 1px solid var(--color-n-200); border-radius: var(--radius-xl); padding: 2.5rem;
  }
  .cta h2 { font-size: clamp(1.5rem, 3vw, 2.1rem); margin: 0 0 0.5rem; }
  .cta .lead { margin: 0; }

  @media (max-width: 900px) {
    .hero-grid { grid-template-columns: 1fr; gap: 1rem; }
    .hero-copy { padding-bottom: 0; }
    .hero-photo { order: 1; }
    .hero-photo img { max-width: 300px; margin-bottom: -1.75rem; }
    .pillars { grid-template-columns: 1fr; }
    .hero-stats { gap: 1.5rem; }
  }
  @media (max-width: 560px) { .hero-creds { grid-template-columns: 1fr; } }
</style>
