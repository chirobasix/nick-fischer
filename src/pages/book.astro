---
import PageLayout from '../layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';
import {
  abs, withBrand,
  buildPerson, buildOrganization, buildWebSite, buildBook, buildWebPage,
} from '../lib/seo';

const title = withBrand("The Chiropractor's Marketing Playbook");
const description =
  "The Chiropractor's Marketing Playbook by Nick Fischer — the step-by-step system for turning a chiropractic practice into a patient magnet with marketing that compounds.";

const jsonLd = [
  buildPerson(),
  buildOrganization(),
  buildWebSite(),
  buildBook({ url: abs('/book/') }),
  buildWebPage({ url: abs('/book/'), name: title, description }),
];

const takeaways = [
  'Build a marketing system instead of chasing one-off campaigns',
  'Turn your website and Google profile into a steady patient pipeline',
  'Make paid ads, SEO, and reputation work together — not against each other',
  'Automate follow-up so no new-patient lead slips through the cracks',
  'Measure what matters and reinvest in what actually grows the practice',
];
---
<PageLayout title={title} description={description} jsonLd={jsonLd}>
  <section class="book-hero">
    <div class="container-page book-grid">
      <div>
        <p class="eyebrow">The Book</p>
        <h1 class="h-display book-title">The Chiropractor's Marketing Playbook</h1>
        <p class="lead book-dek">
          The system I've used to help chiropractors across the country dominate online —
          distilled into a practical, no-fluff playbook you can run in your own practice.
        </p>
        <div class="book-actions">
          <a href="https://www.amazon.com/stores/Nick-Fischer/author/B09VPN4W6S" class="btn btn-primary" target="_blank" rel="noopener">Get it on Amazon <Icon name="lucide:arrow-up-right" width="18" height="18" /></a>
          <a href="/podcast/" class="btn btn-ghost">Hear the ideas in action</a>
        </div>
        <p class="book-note">Available on Amazon — find it on Nick's author page.</p>
      </div>

      <div class="book-cover" aria-hidden="true">
        <div class="cover-spine"></div>
        <div class="cover-face">
          <span class="cover-kicker">Nick Fischer</span>
          <span class="cover-name h-display">The Chiropractor's Marketing Playbook</span>
          <span class="cover-foot">A system for patient generation</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container-page">
      <div class="section-head" data-reveal>
        <p class="eyebrow">Inside the playbook</p>
        <h2 class="h-display">What you'll walk away with</h2>
      </div>
      <ul class="takeaways">
        {takeaways.map((t) => (
          <li class="takeaway" data-reveal><Icon name="lucide:check-circle-2" width="20" height="20" /> {t}</li>
        ))}
      </ul>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container-page who" data-reveal>
      <h2 class="h-display">Who it's for</h2>
      <p class="lead">
        Practice owners who are done guessing — chiropractors who want a clear,
        repeatable marketing system that grows new-patient volume and the long-term
        value of the practice.
      </p>
    </div>
  </section>
</PageLayout>

<style>
  .book-hero { background: linear-gradient(180deg, var(--color-n-50), var(--color-n-0)); padding-block: 4rem; }
  .book-grid { display: grid; grid-template-columns: 1.3fr 1fr; gap: 3rem; align-items: center; }
  .book-title { font-size: clamp(2rem, 4.5vw, 3rem); margin: 0.5rem 0 0; max-width: 16ch; }
  .book-dek { margin-top: 1.25rem; max-width: 52ch; }
  .book-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-top: 1.75rem; }
  .book-note { color: var(--color-n-400); font-size: 0.85rem; margin-top: 1rem; }

  .book-cover { display: flex; justify-content: center; perspective: 1200px; }
  .cover-face {
    width: 260px; aspect-ratio: 2/3; border-radius: 4px 10px 10px 4px;
    background: linear-gradient(150deg, var(--color-navy), var(--color-navy-600));
    color: #fff; padding: 1.75rem; display: flex; flex-direction: column; gap: 1rem;
    box-shadow: var(--shadow-lg); border-left: 6px solid var(--color-gold);
    transform: rotateY(-12deg); transform-style: preserve-3d;
  }
  .cover-kicker { color: var(--color-gold); font-weight: 700; letter-spacing: 0.06em; font-size: 0.85rem; text-transform: uppercase; }
  .cover-name { color: #fff; font-size: 1.5rem; line-height: 1.15; margin-top: auto; }
  .cover-foot { color: var(--color-n-300); font-size: 0.85rem; }

  .section-alt { background: var(--color-n-50); border-block: 1px solid var(--color-n-100); }
  .section-head { max-width: 40ch; margin-bottom: 2rem; }
  .section-head h2 { font-size: clamp(1.6rem, 3.2vw, 2.3rem); margin: 0.5rem 0 0; }

  .takeaways { list-style: none; padding: 0; margin: 0; display: grid; gap: 0.85rem; max-width: 56rem; }
  .takeaway { display: flex; gap: 0.75rem; align-items: start; padding: 1.1rem 1.25rem; background: #fff; border: 1px solid var(--color-n-200); border-radius: var(--radius-md); color: var(--color-n-700); font-size: 1.0625rem; }
  .takeaway [data-icon] { color: var(--color-accent); flex: none; margin-top: 2px; }

  .who { max-width: 50rem; }
  .who h2 { font-size: clamp(1.6rem, 3vw, 2.2rem); margin: 0 0 0.75rem; }

  @media (max-width: 860px) {
    .book-grid { grid-template-columns: 1fr; }
    .book-cover { order: -1; }
  }
</style>
