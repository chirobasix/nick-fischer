---
import { Icon } from 'astro-icon/components';
const year = new Date().getFullYear();
const socials = [
  { href: 'https://www.linkedin.com/in/nfischer83/', label: 'LinkedIn', icon: 'lucide:linkedin' },
  { href: 'https://x.com/nick_fisch_er', label: 'X (Twitter)', icon: 'lucide:twitter' },
  { href: 'https://www.instagram.com/nick.fisch.er', label: 'Instagram', icon: 'lucide:instagram' },
  { href: 'https://www.facebook.com/nfischer83', label: 'Facebook', icon: 'lucide:facebook' },
  { href: 'https://www.youtube.com/@CHIROBASIX', label: 'YouTube', icon: 'lucide:youtube' },
  // Lucide has no TikTok glyph, so this one carries an inline SVG path instead.
  { href: 'https://www.tiktok.com/@chirobasix', label: 'TikTok', svg: 'M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z' },
  { href: 'https://chirobasix.com', label: 'CHIROBASIX', icon: 'lucide:external-link' },
];
---
<footer class="site-footer">
  <div class="container-page foot">
    <div class="foot-brand">
      <a href="/" class="brand" aria-label="Nick Fischer — home">
        <img src="/favicon.svg" alt="" width="36" height="36" />
        <span>Nick Fischer</span>
      </a>
      <p class="foot-tag">
        Helping chiropractors across the country dominate online so they can help more patients.
      </p>
    </div>

    <nav class="foot-nav" aria-label="Footer">
      <a href="/about/">About</a>
      <a href="/speaking/">Speaking</a>
      <a href="/podcast/">Podcast</a>
      <a href="/book/">Book</a>
      <a href="/insights/">Insights</a>
      <a href="/media/">Media</a>
      <a href="/speaker-kit/">Press Kit</a>
      <a href="/contact/">Contact</a>
    </nav>

    <div class="foot-social">
      {socials.map((s) => (
        <a href={s.href} rel="me noopener" target="_blank" aria-label={s.label}>
          {s.svg
            ? <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d={s.svg} /></svg>
            : <Icon name={s.icon} width="20" height="20" />}
        </a>
      ))}
    </div>
  </div>

  <div class="container-page foot-legal">
    <p>&copy; {year} Nick Fischer. All rights reserved.</p>
    <p>Founder of <a href="https://chirobasix.com" rel="noopener" target="_blank">CHIROBASIX</a>.</p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-navy);
    color: var(--color-n-200);
    padding-block: 3.5rem 1.5rem;
    margin-top: 2rem;
  }
  .foot {
    display: grid;
    grid-template-columns: 1.6fr 1fr auto;
    gap: 2.5rem;
    align-items: start;
  }
  .brand {
    display: inline-flex; align-items: center; gap: 0.6rem;
    font-family: var(--font-display); font-weight: 800; font-size: 1.15rem;
    color: #fff;
  }
  .brand img { border-radius: 8px; }
  .foot-tag { margin: 1rem 0 0; max-width: 34ch; color: var(--color-n-300); font-size: 0.95rem; }

  .foot-nav { display: flex; flex-direction: column; gap: 0.75rem; }
  .foot-nav a { color: var(--color-n-200); font-size: 0.95rem; }
  .foot-nav a:hover { color: #fff; }

  .foot-social { display: flex; gap: 0.75rem; }
  .foot-social a {
    display: inline-flex; align-items: center; justify-content: center;
    width: 40px; height: 40px; border-radius: 999px;
    background: rgba(255,255,255,.08); color: #fff;
    transition: background var(--duration-base) var(--ease-out);
  }
  .foot-social a:hover { background: var(--color-accent); }

  .foot-legal {
    display: flex; justify-content: space-between; flex-wrap: wrap; gap: 0.5rem;
    margin-top: 2.5rem; padding-top: 1.5rem;
    border-top: 1px solid rgba(255,255,255,.12);
    font-size: 0.85rem; color: var(--color-n-300);
  }
  .foot-legal a { color: var(--color-n-200); text-decoration: underline; }

  @media (max-width: 720px) {
    .foot { grid-template-columns: 1fr; gap: 2rem; }
  }
</style>
