---
// Sticky top nav. Pure HTML/CSS — the mobile menu uses a checkbox toggle so
// there is zero JavaScript shipped for navigation.
const { pathname } = Astro.url;
const links = [
  { href: '/about/', label: 'About' },
  { href: '/speaking/', label: 'Speaking' },
  { href: '/podcast/', label: 'Podcast' },
  { href: '/book/', label: 'Book' },
  { href: '/insights/', label: 'Insights' },
];
const isActive = (href: string) => pathname === href;
---
<header class="site-header">
  <nav class="container-page nav" aria-label="Primary">
    <a href="/" class="brand" aria-label="Nick Fischer — home">
      <img src="/favicon.svg" alt="" width="32" height="32" />
      <span>Nick Fischer</span>
    </a>

    <input type="checkbox" id="nav-toggle" class="nav-toggle" aria-hidden="true" />
    <label for="nav-toggle" class="nav-burger" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </label>

    <div class="nav-links">
      {links.map((l) => (
        <a href={l.href} class:list={['nav-link', { active: isActive(l.href) }]} aria-current={isActive(l.href) ? 'page' : undefined}>
          {l.label}
        </a>
      ))}
      <a href="/contact/" class="btn btn-primary nav-cta">Get in touch</a>
    </div>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--color-n-0) 86%, transparent);
    backdrop-filter: saturate(180%) blur(10px);
    border-bottom: 1px solid var(--color-n-100);
  }
  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 64px;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-display);
    font-weight: 800;
    letter-spacing: -0.01em;
    font-size: 1.0625rem;
    color: var(--color-ink);
  }
  .brand img { border-radius: 7px; }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }
  .nav-link {
    font-weight: 550;
    font-size: 0.95rem;
    color: var(--color-n-600);
    transition: color var(--duration-base) var(--ease-out);
  }
  .nav-link:hover, .nav-link.active { color: var(--color-accent); }
  .nav-cta { padding: 0.6rem 1.1rem; font-size: 0.9rem; }

  /* Mobile toggle is hidden on desktop */
  .nav-toggle, .nav-burger { display: none; }

  @media (max-width: 860px) {
    .nav-burger {
      display: inline-flex;
      flex-direction: column;
      gap: 5px;
      cursor: pointer;
      padding: 8px;
    }
    .nav-burger span {
      width: 24px; height: 2px; background: var(--color-ink); border-radius: 2px;
      transition: transform var(--duration-base) var(--ease-out), opacity var(--duration-base);
    }
    .nav-links {
      position: absolute;
      top: 64px; left: 0; right: 0;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      background: var(--color-n-0);
      border-bottom: 1px solid var(--color-n-100);
      box-shadow: var(--shadow-md);
      max-height: 0;
      overflow: hidden;
      transition: max-height var(--duration-base) var(--ease-out);
    }
    .nav-links > * {
      padding: 0.9rem 1.25rem;
      border-top: 1px solid var(--color-n-100);
    }
    .nav-cta { margin: 0.75rem 1.25rem; text-align: center; }
    .nav-toggle:checked ~ .nav-links { max-height: 24rem; }
    .nav-toggle:checked ~ .nav-burger span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .nav-toggle:checked ~ .nav-burger span:nth-child(2) { opacity: 0; }
    .nav-toggle:checked ~ .nav-burger span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
  }
</style>
